# Logs (often huge, often contain production data)
*.log
*.log.gz
*.log.zip

# Index dumps (production schema info)
*.csv
*.xlsx
*.xls

# ...except the synthetic test fixtures, which must ship with the repo
# so the test suite works on a fresh clone.
!tests/fixtures/*.csv
!tests/fixtures/*.log

# Generated reports
*.html
!docs/**/*.html

# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env
.envrc
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp

# Temp / scratch
report_smoke.html
tmp/
scratch/
